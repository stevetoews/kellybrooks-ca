---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const paintings = await getCollection('paintings');
paintings.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Kelly Brooks">
  <div class="gallery-grid px-4 py-8 sm:px-6 lg:px-8">
    {paintings.map((p) => (
      <a
        href={`/${p.id}/`}
        class="gallery-item"
        title={p.data.title}
      >
        {p.data.image && (
          <img
            src={p.data.image}
            alt={p.data.title}
            decoding="async"
          />
        )}
      </a>
    ))}
  </div>
</Layout>

<script>
  function runCascade() {
    const items = [...document.querySelectorAll<HTMLElement>('.gallery-item')];

    // Read real rendered positions — only valid after images have loaded and
    // given the browser their natural dimensions.
    const sorted = items
      .map(el => ({ el, rect: el.getBoundingClientRect() }))
      .sort((a, b) => {
        // Bucket items into ~100px horizontal bands so items at the same
        // visual height animate together before we break ties left → right.
        const bandPx = 100;
        const rowA = Math.floor(a.rect.top / bandPx);
        const rowB = Math.floor(b.rect.top / bandPx);
        return rowA !== rowB ? rowA - rowB : a.rect.left - b.rect.left;
      });

    sorted.forEach(({ el }, i) => {
      el.style.transitionDelay = `${i * 120}ms`;
      el.classList.add('visible');
    });
  }

  // window.load fires after every image has loaded and has natural dimensions,
  // so getBoundingClientRect().top/.left are correct for the full masonry layout.
  if (document.readyState === 'complete') {
    runCascade();
  } else {
    window.addEventListener('load', runCascade, { once: true });
  }
</script>

<style>
  .gallery-grid {
    columns: 1;
    column-gap: 8px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 8px;
    display: block;
    overflow: hidden;

    opacity: 0;
    transform: translateY(8px);
    transition: opacity 1.1s ease, transform 1.1s ease;
  }

  .gallery-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Hover only after item is visible so there's no flash during load */
  .gallery-item.visible:hover {
    opacity: 0.87;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 640px) {
    .gallery-grid { columns: 2; }
  }

  @media (min-width: 1024px) {
    .gallery-grid { columns: 3; }
  }
</style>
