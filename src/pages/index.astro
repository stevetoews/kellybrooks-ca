---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const paintings = await getCollection('paintings');
paintings.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Kelly Brooks">
  <div class="gallery-grid px-4 py-8 sm:px-6 lg:px-8">
    {paintings.map((p) => (
      <a
        href={`/${p.id}/`}
        class="gallery-item"
        title={p.data.title}
      >
        {p.data.image && (
          <img
            src={p.data.image}
            alt={p.data.title}
            loading="lazy"
            decoding="async"
          />
        )}
      </a>
    ))}
  </div>
</Layout>

<script>
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');
  let firstBatch = true;

  const observer = new IntersectionObserver(
    (entries) => {
      // Sort visible items top-to-bottom, left-to-right for a natural cascade
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => {
          const dy = a.boundingClientRect.top - b.boundingClientRect.top;
          return dy !== 0 ? dy : a.boundingClientRect.left - b.boundingClientRect.left;
        });

      visible.forEach((entry, i) => {
        const el = entry.target as HTMLElement;
        // Initial load: generous stagger so the cascade reads clearly
        // Scroll reveals: tighter stagger so it feels responsive
        const stagger = firstBatch ? 130 : 80;
        el.style.transitionDelay = `${i * stagger}ms`;
        el.classList.add('visible');
        observer.unobserve(el);
      });

      firstBatch = false;
    },
    {
      threshold: 0.04,
      rootMargin: '0px 0px -12px 0px',
    }
  );

  items.forEach(item => observer.observe(item));
</script>

<style>
  .gallery-grid {
    columns: 1;
    column-gap: 8px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 8px;
    display: block;
    overflow: hidden;

    /* Start hidden */
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 1.1s ease,
      transform 1.1s ease;
  }

  /* Hover brightness — only once visible so it doesn't flash on load */
  .gallery-item.visible:hover {
    opacity: 0.88;
  }

  .gallery-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (min-width: 640px) {
    .gallery-grid { columns: 2; }
  }

  @media (min-width: 1024px) {
    .gallery-grid { columns: 3; }
  }
</style>
