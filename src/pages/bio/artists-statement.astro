---
import Layout from '../../layouts/Layout.astro';
import statementData from '../../data/pages/artists-statement.json';
---

<Layout title="Artist's Statement">
  <div class="max-w-2xl mx-auto px-6 py-16">
    <p class="text-sm text-gray-400 mb-2">
      <a href="/bio/" class="hover:opacity-60 transition-opacity">&larr; Bio</a>
    </p>
    <h1 class="text-2xl font-medium mb-8">Artist's Statement</h1>
    {statementData.html ? (
      <div class="prose prose-sm max-w-none" set:html={statementData.html} />
    ) : (
      <p class="text-gray-500 italic">Statement coming soon.</p>
    )}
  </div>
</Layout>
