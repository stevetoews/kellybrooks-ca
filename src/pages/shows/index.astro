---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import showsData from '../../data/pages/shows.json';

const shows = await getCollection('shows');
shows.sort((a, b) => {
  const da = a.data.date || '';
  const db = b.data.date || '';
  return db.localeCompare(da); // newest first
});
---

<Layout title="Shows">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-2xl font-medium mb-8">Shows</h1>

    {showsData.html && (
      <div class="prose prose-sm max-w-none mb-12 text-gray-600" set:html={showsData.html} />
    )}

    <ul class="space-y-4">
      {shows.map((show) => (
        <li>
          <a
            href={`/shows/${show.id}/`}
            class="group flex items-baseline gap-3 hover:opacity-70 transition-opacity"
          >
            {show.data.date && (
              <time class="text-xs text-gray-400 shrink-0 w-20">
                {new Date(show.data.date + 'T12:00:00').toLocaleDateString('en-CA', { year: 'numeric', month: 'short' })}
              </time>
            )}
            <span class="font-medium group-hover:underline underline-offset-2">
              {show.data.title}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
