---
import Layout from '../../layouts/Layout.astro';
import Slider from '../../components/Slider.astro';
import showsData from '../../data/pages/shows.json';

const SHOWS_SLIDER = [
  '/images/mt-vernon-1024-960x600.jpg',
  '/images/waterfront-1024-960x600.jpg',
  '/images/group-1024-960x600.jpg',
];
---

<Layout title="Shows">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="page-title">Shows</h1>

    <div class="mb-12">
      <Slider images={SHOWS_SLIDER} label="Exhibition photos" interval={5000} />
    </div>

    {showsData.html && (
      <div class="prose" set:html={showsData.html} />
    )}
  </div>
</Layout>

<style>
  .page-title {
    font-family: 'Lato', sans-serif;
    font-size: 25px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #222;
    margin: 0 0 32px;
  }
</style>
